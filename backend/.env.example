# Backend Environment Variables Template
# Copy this file to a new '.env' file in the same directory and configure the values.

# The port the backend server listens on
PORT=3000

# The URL of the frontend application (used for CORS and auth links)
FRONTEND_URL=http://localhost:5173

# The connection string for MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/

# The name of the MongoDB database to connect to
DB_NAME=ims-main

# JSON Web Token secrets (generate long, secure random strings)
JWT_ACCESS_SECRET=your_super_secret_access_key
JWT_REFRESH_SECRET=your_super_secret_refresh_key

# Administrator email address
ADMIN_MAIL=admin@example.com

# Node environment setting (development or production)
NODE_ENV=development
